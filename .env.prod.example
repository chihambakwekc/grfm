POSTGRES_DB=grfm_db
POSTGRES_USER=grfm_user
POSTGRES_PASSWORD=replace-with-strong-password
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=grfm.example.com,portal.grfm.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://grfm.example.com,https://portal.grfm.example.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DATABASE_URL=postgresql://grfm_user:replace-with-strong-password@db:5432/grfm_db
REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=https://grfm.example.com,https://portal.grfm.example.com
VITE_API_BASE_URL=/api/
PROXY_HOST_ALIAS=grfm-app
NPM_NETWORK=proxy
